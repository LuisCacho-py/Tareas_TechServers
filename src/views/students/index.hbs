<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-1">Lista de alumnos</h1>
    <p class="text-muted mb-0">Vista principal del CRUD</p>
  </div>
  <a href="/alumnos/new" class="btn btn-primary">Nuevo alumno</a>
</div>

{{#if ok}}
  <div class="alert alert-success">{{ok}}</div>
{{/if}}

{{#if err}}
  <div class="alert alert-danger">{{err}}</div>
{{/if}}

{{#if students.length}}
  <div class="card shadow-sm">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle mb-0">
          <thead class="table-dark">
            <tr>
              <th>Nombre</th>
              <th>Correo</th>
              <th>Expediente</th>
              <th>Semestre</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#each students}}
              <tr>
                <td>{{this.nombre}}</td>
                <td>{{this.correo}}</td>
                <td>{{this.expediente}}</td>
                <td>{{this.semestre}}</td>
                <td class="d-flex gap-2">
                  <a href="/alumnos/edit/{{this._id}}" class="btn btn-warning btn-sm">Editar</a>

                  <form action="/alumnos/{{this._id}}?_method=DELETE" method="POST" class="m-0">
                    <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                  </form>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
{{else}}
  <div class="alert alert-secondary">
    No hay alumnos guardados
  </div>
{{/if}}